SOLAR_API_KEY=
SOLAR_BASE_URL=https://api.upstage.ai/v1
# 수집 파이프라인 관련성 필터는 이 모델로 Solar Mini API를 호출합니다.
# 키가 비어 있거나 호출이 실패하면 로컬 키워드 기반 판정으로 fallback합니다.
SOLAR_MINI_MODEL=solar-mini
SOLAR_DIGEST_MODEL=solar-pro3
LOG_LEVEL=INFO

# 스케줄러 설정 (선택)
# SCHEDULER_ENABLED=true
# SCHEDULER_TIME=09:00
# SCHEDULER_TIMEZONE=Asia/Seoul
# SCHEDULER_SOURCES=huggingface,hackernews
# 앱 부팅 시 스케줄러 루프 + 효력 일자 다이제스트 자동 생성을 시작합니다.
# SCHEDULER_AUTOSTART=1

# 데모/시연용: 부팅 시 시연 상태를 모두 비웁니다.
#   - 벡터DB(ChromaDB) 컬렉션
#   - 다이제스트 파일 (data/digests/digest_*.json)
#   - 수집 상태 파일 (data/collection_status.json)
# 평소엔 비활성 상태로 두고, 시연 직전에만 1로 켜는 것을 권장합니다.
# CHROMA_RESET_ON_STARTUP=1

# 데모 전용: 앱 부팅 직후 효력 일자 직전 N일치 수집과 Digest 생성을 백그라운드로 실행합니다.
# 실제 외부 수집, 임베딩, Solar Mini/Pro 호출 비용이 발생하므로 데모 준비 시에만 켜세요.
# DEMO_BOOTSTRAP_ON_STARTUP=1
# DEMO_BOOTSTRAP_DAYS=5
