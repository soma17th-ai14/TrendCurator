SOLAR_API_KEY=
SOLAR_BASE_URL=https://api.upstage.ai/v1
SOLAR_MINI_MODEL=solar-mini
SOLAR_DIGEST_MODEL=solar-pro3

# 스케줄러 설정 (선택)
# SCHEDULER_ENABLED=true
# SCHEDULER_TIME=09:00
# SCHEDULER_TIMEZONE=Asia/Seoul
# SCHEDULER_SOURCES=huggingface,hackernews
# 앱 부팅 시 스케줄러 루프 + 효력 일자 다이제스트 자동 생성을 시작합니다.
# SCHEDULER_AUTOSTART=1

# 데모/시연용: 부팅 시 ChromaDB 컬렉션을 한 번 비웁니다.
# 평소엔 비활성 상태로 두고, 시연 직전에만 1로 켜는 것을 권장합니다.
# CHROMA_RESET_ON_STARTUP=1
